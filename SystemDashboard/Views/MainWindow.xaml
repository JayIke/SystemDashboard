<Window x:Class="SystemDashboard.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Dashboard" Height="300" Width="400"
        Background="#1E1E1E">

    <Grid Margin="20">
        <StackPanel>

            <TextBlock Text="System Dashboard"
                       FontSize="22"
                       Foreground="White"
                       Margin="0 0 0 20"/>

            <TextBlock Text="CPU Usage"
                       Foreground="White"/>

            <ProgressBar Value="{Binding CpuUsage}"
                         Maximum="100"
                         Height="20"
                         Margin="0 0 0 10"/>

            <TextBlock Text="{Binding CpuUsage, StringFormat='CPU: {0:F1}%'}"
                       Foreground="White"
                       Margin="0 0 0 20"/>

            <TextBlock Text="RAM Usage"
                       Foreground="White"/>

            <ProgressBar Value="{Binding RamUsage}"
                         Maximum="100"
                         Height="20"
                         Margin="0 0 0 10"/>

            <TextBlock Text="{Binding RamUsage, StringFormat='RAM: {0:F1}%'}"
                       Foreground="White"/>

        </StackPanel>
    </Grid>
</Window>